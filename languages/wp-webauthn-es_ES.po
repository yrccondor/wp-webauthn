#. Plugin Name of the plugin
#: wp-webauthn.php
msgid "WP-WebAuthn"
msgstr "WP-WebAuthn"

#. Plugin URI of the plugin
#: wp-webauthn.php
msgid "https://flyhigher.top"
msgstr "https://flyhigher.top"

#. Description of the plugin
#: wp-webauthn.php
msgid ""
"WP-WebAuthn allows you to safely login to your WordPress site without "
"password."
msgstr ""
"WP-WebAuthn te permite iniciar sesión de forma segura en tu sitio de "
"WordPress sin necesidad de contraseña."

#. Author of the plugin
#: wp-webauthn.php
msgid "Axton"
msgstr "Axton"

#. Author URI of the plugin
#: wp-webauthn.php
msgid "https://axton.cc"
msgstr "https://axton.cc"

#: wwa-admin-content.php:11 wwa-network-admin-content.php:98
msgid ""
"User verification is disabled by default because some mobile devices do not "
"support it (especially on Android devices). But we <strong>recommend you to "
"enable it</strong> if possible to further secure your login."
msgstr ""
"La verificación de usuario está desactivada de forma predeterminada porque "
"algunos dispositivos móviles no la admiten (especialmente los dispositivos "
"Android). Sin embargo, en <strong>te recomendamos que la actives</strong> si "
"es posible, para reforzar la seguridad de tu inicio de sesión."

#: wwa-admin-content.php:12 wwa-admin-content.php:446
#: wwa-network-admin-content.php:99
msgid "Log count: "
msgstr "Número de registros: "

#: wwa-admin-content.php:13 wwa-network-admin-content.php:100
